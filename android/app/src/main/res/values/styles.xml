<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your theme here. -->
        <item name="android:editTextBackground">@drawable/rn_edit_text_material</item>
        <item name="colorPrimary">@color/picker_primary</item>
        <item name="colorOnPrimary">@color/picker_on_primary</item>
        <item name="colorSurface">@color/picker_surface</item>
        <item name="colorOnSurface">@color/picker_on_surface</item>
        <item name="colorOnSurfaceVariant">@color/picker_on_surface_variant</item>
        <item name="materialCalendarTheme">@style/WorkNest.MaterialCalendar</item>
        <item name="materialTimePickerTheme">@style/WorkNest.MaterialTimePicker</item>
    </style>

    <style name="WorkNest.MaterialCalendar" parent="ThemeOverlay.Material3.MaterialCalendar">
        <item name="colorPrimary">@color/picker_primary</item>
        <item name="colorOnPrimary">@color/picker_on_primary</item>
        <item name="colorSurface">@color/picker_surface</item>
        <item name="colorOnSurface">@color/picker_on_surface</item>
        <item name="colorOnSurfaceVariant">@color/picker_on_surface_variant</item>
    </style>

    <style name="WorkNest.MaterialTimePicker" parent="ThemeOverlay.Material3.MaterialTimePicker">
        <item name="colorPrimary">@color/picker_primary</item>
        <item name="colorOnPrimary">@color/picker_on_primary</item>
        <item name="colorSurface">@color/picker_surface</item>
        <item name="colorOnSurface">@color/picker_on_surface</item>
        <item name="colorOnSurfaceVariant">@color/picker_on_surface_variant</item>
    </style>

</resources>
